# =========================
# MCP Server Environment Variables
# =========================
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# Required: Admin token for the MCP admin server
# Generate a secure random token, e.g.: openssl rand -hex 32
MCP_ADMIN_TOKEN=

# Optional: Comma-separated list of allowed CORS origins
# MCP_ALLOWED_ORIGINS=https://example.com,https://app.example.com

# Optional: Comma-separated list of allowed client IPs
# MCP_ALLOWED_IPS=

# Optional: Override default ports
# MCP_PORT=8787
# MCP_ADMIN_PORT=8788

# Optional: Override workspace and log paths
# MCP_WORKSPACE=/workspace
# MCP_LOG_DIR=/opt/mcp/logs
